import pandas as pd
import numpy as np
import plotly.express as px
import plotly.graph_objects as go
import streamlit as st

# Charge ton CSV (uploadé ou généré)
@st.cache_data
def load_data():
    # Colle ici les données du CSV ou simule comme ci-dessous
    np.random.seed(42)
    months = ['Oct-25', 'Nov-25', 'Dec-25', 'Jan-26', 'Feb-26', 'Mar-26']
    regions = ['Region A (North)', 'Region B (South)', 'Region C (East)', 'Region D (West)']
    projects = ['Vaccination Drive', 'School Access', 'Protection from Violence']
    data = []
    for month in months:
        for region in regions:
            for proj in projects:
                data.append({
                    'Month': month, 'Region': region, 'Project': proj,
                    'Children_Reached': np.random.randint(500, 5000),
                    'Target': np.random.randint(4000, 8000),
                    'Progress_Pct': np.random.uniform(70, 110),
                    'Funding_Utilized_Pct': np.random.uniform(75, 105),
                    'Cost_Per_Child': np.random.uniform(20, 80),
                    'Satisfaction_Score': np.random.uniform(7.5, 9.5)
                })
    return pd.DataFrame(data)

df = load_data()

st.title("🛡️ UNICEF Child Protection Dashboard")

# Metrics
col1, col2, col3 = st.columns(3)
total_reached = df['Children_Reached'].sum()
col1.metric("Total Children Reached", f"{total_reached:,}")
col2.metric("Overall Progress", f"{(total_reached / df['Target'].sum() * 100):.1f}%")
col3.metric("Avg Satisfaction", f"{df['Satisfaction_Score'].mean():.1f}/10")

# Filters
col_f1, col_f2, col_f3 = st.columns(3)
month_filter = col_f1.multiselect("Month", df['Month'].unique(), default=df['Month'].unique())
region_filter = col_f2.multiselect("Region", df['Region'].unique(), default=df['Region'].unique())
project_filter = col_f3.multiselect("Project", df['Project'].unique(), default=df['Project'].unique())

df_filtered = df[(df['Month'].isin(month_filter)) &
                 (df['Region'].isin(region_filter)) &
                 (df['Project'].isin(project_filter))]

# Charts
st.subheader("Children Reached Over Time")
fig1 = px.line(df_filtered.groupby('Month')['Children_Reached'].sum().reset_index(),
               x='Month', y='Children_Reached', title="Reached vs Targets")
st.plotly_chart(fig1, use_container_width=True)

st.subheader("By Region")
fig2 = px.bar(df_filtered.groupby('Region')['Children_Reached'].sum().reset_index(),
              x='Region', y='Children_Reached', color='Children_Reached')
st.plotly_chart(fig2, use_container_width=True)

st.subheader("Progress Heatmap")
fig3 = px.imshow(df_filtered.pivot_table(values='Progress_Pct', index='Region', columns='Project'),
                 title="Progress % Heatmap", color_continuous_scale='RdYlGn')
st.plotly_chart(fig3, use_container_width=True)

st.subheader("By Project")
fig4 = px.pie(df_filtered, values='Children_Reached', names='Project')
st.plotly_chart(fig4, use_container_width=True)

# Alerts
low_progress = df_filtered[df_filtered['Progress_Pct'] < 80]
if not low_progress.empty:
    st.warning(f"🚨 Alert: {len(low_progress)} regions/projects below 80% progress!")
